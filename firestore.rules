rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
    }
    match /{collection}/{id} {
      allow write: if collection in ['planets', 'planetary_systems', 'entities', 'books', 'timeline_events']
        && request.auth != null
        && request.auth.token.email in ['alex@upliftcampaigns.com'];
    }
  }
}
