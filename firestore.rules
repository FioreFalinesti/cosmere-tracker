rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedInEmail() {
      return request.auth.token.email.lower();
    }
    function isRoot() {
      return request.auth != null && signedInEmail() == 'f.falinesti@gmail.com';
    }
    function isAdmin() {
      return request.auth != null &&
        (isRoot() || exists(/databases/$(database)/documents/admins/$(signedInEmail())));
    }

    // Admin roster. Deliberately excluded from the catch-all read below so it
    // can't be enumerated by anyone but admins; a user may still check their
    // own doc to resolve their own admin status client-side.
    match /admins/{email} {
      allow get: if request.auth != null && (signedInEmail() == email || isAdmin());
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /{collection}/{id} {
      allow read: if collection != 'admins';
      allow write: if collection in ['planets', 'planetary_systems', 'entities', 'books', 'timeline_events']
        && isAdmin();
    }
  }
}
